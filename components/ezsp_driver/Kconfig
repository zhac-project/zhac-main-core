menu "ZHAC EZSP NCP"
    config ZHAC_EZSP_BACKEND_ENABLE
        bool "EZSP/ASH backend (EXPERIMENTAL — known-broken link layer, see extra/docs/EZSP_ASH_REWORK_PLAN.md)"
        default n
        help
            Compiles the experimental Silicon Labs EZSP/ASH NCP backend
            (components ezsp_driver + ezsp_backend) into the firmware and
            unlocks the "Silicon Labs EmberZNet" option in the NCP Protocol
            choice. The ASH link layer is structurally incomplete (F14):
            no retransmit path, conflated ACK counters, and the response
            semaphore is only serviced from the caller's own poll loop
            (C3/C4 deadlock). Do NOT ship with this enabled — bench
            bring-up only. Rework plan:
            extra/docs/EZSP_ASH_REWORK_PLAN.md (workspace-local).

    if ZHAC_EZSP_BACKEND_ENABLE

    config ZHAC_EZSP_UART_TX_GPIO
        int "EZSP UART TX GPIO pin"
        default 26
        help
            GPIO pin connected to EFR32 NCP UART RX (host TX → NCP RX).
            Default IO26 per UART expansion allocation in GPIO doc.

    config ZHAC_EZSP_UART_RX_GPIO
        int "EZSP UART RX GPIO pin"
        default 27
        help
            GPIO pin connected to EFR32 NCP UART TX (NCP TX → host RX).
            Default IO27 per UART expansion allocation in GPIO doc.

    config ZHAC_EZSP_UART_RST_GPIO
        int "EZSP Reset GPIO pin"
        default 28
        help
            GPIO pin connected to EFR32 NCP nRESET.
            Default IO28 (shared reset line).

    endif # ZHAC_EZSP_BACKEND_ENABLE
endmenu
